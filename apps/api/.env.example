# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ropqa:ropqa@localhost:5432/ropqa

# ─── Redis / Celery ──────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ─── Storage (S3 / LocalStack) ───────────────────────────────────────────────
S3_BUCKET=ropqa-artifacts
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_REGION=us-east-1
# Point to LocalStack for local dev; leave empty for real AWS
S3_ENDPOINT_URL=http://localhost:4566

# ─── Auth (Clerk) ────────────────────────────────────────────────────────────
# Clerk Dashboard → API Keys
CLERK_SECRET_KEY=sk_test_...
# Clerk Dashboard → API → JWKS URL
CLERK_JWKS_URL=https://your-subdomain.clerk.accounts.dev/.well-known/jwks.json
# Clerk Dashboard → Webhooks → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_...

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ─── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@ropqa.com

# ─── App ─────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
DEBUG=true
